            ))}

          </tbody>

        </table>

        {/* Empty State */}
        {(!incidents || incidents.length === 0) && (

          <div className="p-8 text-center text-slate-500">
            No incidents found matching criteria.
          </div>

        )}

      </div>

    </div>
  );
}
