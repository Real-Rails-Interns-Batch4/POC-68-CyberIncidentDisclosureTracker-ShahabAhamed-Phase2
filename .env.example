# Cyber Incident Disclosure Tracker - Environment Configuration

# SEC EDGAR Integration
# API URL for fetching recent SEC filings
SEC_EDGAR_API_URL=https://data.sec.gov/submissions/CIK0000320193.json
# User-Agent string required by SEC EDGAR API (Format: AppName/Version (ContactEmail))
SEC_EDGAR_USER_AGENT=CyberRailTracker/1.0 (admin@example.com)

# GDELT Integration
# Base API URL for GDELT Doc 2.0 API
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
# Query string for relevant cyber intelligence
GDELT_QUERY="cyber incident OR data breach"

# Database/API settings (if applicable)
# BACKEND_URL=http://localhost:8000
