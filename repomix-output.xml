    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      top: '10%',
      containLabel: true
    },
    xAxis: {
      type: "category",
      data: sectors,
      axisLabel: {
        color: '#94a3b8',
        fontSize: 11,
      },
      axisLine: {
        lineStyle: {
          color: '#1e293b'
        }
      }
    },
