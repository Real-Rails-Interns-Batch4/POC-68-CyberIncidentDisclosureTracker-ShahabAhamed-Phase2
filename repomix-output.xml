      type: "value",
      splitLine: {
        lineStyle: {
          color: '#1e293b',
          type: 'dashed'
        }
      },
      axisLabel: {
        color: '#94a3b8',
        fontSize: 11,
      }
    },
    series: [
      {
        data: values,
        type: "bar",
        itemStyle: {
          color: {
            type: 'linear',
            x: 0,
            y: 0,
            x2: 0,
            y2: 1,
            colorStops: [{
